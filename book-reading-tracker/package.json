{
  "name": "book-reading-tracker",
  "version": "1.0.0",
  "description": "A TypeScript-based book reading tracker with Express backend and MongoDB storage",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node --loader ts-node/esm src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongodb": "^6.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/cors": "^2.8.13",
    "typescript": "^5.1.3",
    "ts-node": "^10.9.1"
  }
}
